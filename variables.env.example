# Copy this file to `variables.env` (which is gitignored) and fill in values.
#
# Notes:
# - For multiline keys (like Firebase private keys), keep it on ONE LINE and use \n for newlines.
# - Never commit `variables.env`.

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Firebase Admin (used by Cloud Functions via Firebase Secrets / process.env)
FB_CLIENT_EMAIL=
FB_PRIVATE_KEY=
